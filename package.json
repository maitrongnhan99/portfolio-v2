  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -- next dev -p 3000",
    "build": "dotenvx run -- next build --webpack",
    "start": "dotenvx run -- next start -p 3000",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "seed-knowledge": "dotenvx run -- tsx scripts/seed-knowledge-qdrant.ts",
    "seed-knowledge:clear": "dotenvx run -- tsx scripts/seed-knowledge-qdrant.ts --clear",
    "seed-knowledge:dry-run": "dotenvx run -- tsx scripts/seed-knowledge-qdrant.ts --dry-run",
    "seed-knowledge:static": "dotenvx run -- tsx scripts/seed-knowledge-qdrant.ts --static-only",
    "seed-knowledge:projects": "dotenvx run -- tsx scripts/seed-knowledge-qdrant.ts --projects-only",
    "migrate-vector-dimensions": "dotenvx run -- tsx scripts/migrate-vector-dimensions.ts",
    "test-qdrant": "dotenvx run -- tsx scripts/test-qdrant-integration.ts",
    "migrate:payload": "dotenvx run -- tsx scripts/migrate-to-payload.ts",
    "migrate:payload:force": "dotenvx run -f FORCE_MIGRATION=true -- tsx scripts/migrate-to-payload.ts",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest tests/services tests/utils",
    "test:integration": "vitest tests/api",
    "test:performance": "vitest tests/performance",
    "test:e2e": "vitest tests/e2e",
    "test:ci": "vitest run --coverage",
    "test:ci:coverage": "vitest run --coverage --config vitest.config.ci.mjs",
    "test:verbose": "VERBOSE_TESTS=1 vitest --reporter=verbose",
    "test:ui": "vitest --ui"
  },
