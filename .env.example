TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key


# Payload CMS Configuration
PAYLOAD_SECRET=your-secure-payload-secret-min-32-chars
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
SERVER_URL=http://localhost:3000

# Database Configuration (Vercel Postgres)
POSTGRES_URL=your-vercel-postgres-connection-string

# Payload Features
PAYLOAD_ENABLED=true

# Cloud Storage (Vercel Blob) - Optional
# Get this token from your Vercel project dashboard after enabling Blob storage
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Email Configuration with Resend
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Portfolio CMS